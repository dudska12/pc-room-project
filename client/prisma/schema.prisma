// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

// 1. 사용자 (User) - 회원 정보 및 잔여 시간 관리
model User {
  id            String @id @default(uuid())
  userId        String @unique
  password      String
  name          String
  remainingTime Int    @default(0)
  point         Int    @default(0)
  role          Role   @default(USER)

  // [추가] 현재 사용 중인 좌석과의 관계 (1:1)
  currentSeat Seat? @relation("UserCurrentSeat")

  logs      UsageLog[]
  orders    Order[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

enum Role {
  USER
  ADMIN
}

// 2. 좌석 (Seat) - 실시간 PC 상태 및 사용 정보
model Seat {
  id         Int        @id @default(autoincrement())
  seatNumber Int        @unique
  status     SeatStatus @default(AVAILABLE)

  // [수정] String 대신 User 모델과 직접 연결
  user          User?   @relation("UserCurrentSeat", fields: [currentUserId], references: [id])
  currentUserId String? @unique // 한 유저는 한 자리만 점유 가능

  // [추가] 실시간 동기화를 위한 체크 포인트
  // 강제 종료 로직 시, (현재 시간 - lastHeartbeat)만큼 시간을 차감하기 위함
  lastHeartbeat DateTime?

  startTime DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

enum SeatStatus {
  AVAILABLE // 사용 가능
  OCCUPIED // 사용 중
  REPAIR // 수리 중
  RESERVED // 예약됨
}

// 3. 상품 (Product) - 먹거리 및 서비스 관리 (재고/설명 포함)
model Product {
  id       Int    @id @default(autoincrement())
  name     String // 상품명 (예: 신라면)
  category String // 카테고리 (라면, 음료, 과자, 요금제)
  price    Int    @default(0)

  // 상세 정보
  description String? @db.Text // 상품 상세 설명
  stock       Int     @default(0) // 현재 재고 수량
  imageUrl    String? // 이미지 주소 (Supabase Storage URL)
  isAvailable Boolean @default(true) // 판매 가능 여부

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 관계 설정
  orderItems OrderItem[]
}

// 4. 주문 (Order) - 사용자의 상품 주문 내역
model Order {
  id         Int         @id @default(autoincrement())
  user       User        @relation(fields: [userId], references: [id])
  userId     String
  seatNumber Int // 주문한 좌석 번호
  totalPrice Int // 총 주문 금액
  status     OrderStatus @default(PENDING)
  createdAt  DateTime    @default(now())

  items OrderItem[]
}

enum OrderStatus {
  PENDING // 주문 확인 중
  COOKING // 조리 중
  COMPLETED // 완료(서빙됨)
  CANCELLED // 취소됨
}

// 5. 주문 상세 (OrderItem) - 하나의 주문에 담긴 여러 상품들
model OrderItem {
  id        Int     @id @default(autoincrement())
  order     Order   @relation(fields: [orderId], references: [id])
  orderId   Int
  product   Product @relation(fields: [productId], references: [id])
  productId Int
  quantity  Int // 주문 수량
}

// 6. 이용 기록 (UsageLog) - 유저별 PC 사용 히스토리
model UsageLog {
  id         Int       @id @default(autoincrement())
  user       User      @relation(fields: [userId], references: [id])
  userId     String
  seatNumber Int
  startTime  DateTime  @default(now())
  endTime    DateTime?
  usedTime   Int?
  status     LogStatus @default(NORMAL) // NORMAL, FORCED_EXIT (강제종료)
}

enum LogStatus {
  NORMAL
  FORCED_EXIT
}
